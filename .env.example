# Token del bot de Discord (obligatorio).
DISCORD_TOKEN=

# ID de la aplicación (obligatorio para slash commands sincronizados al instante).
APPLICATION_ID=

# ID del usuario que actúa como propietario global del bot. Es el fallback de
# autorización admin cuando un servidor todavía no tiene su propio `bot_owner_id`
# configurado en `guild_config`. Opcional — si falta o no es numérico, el fallback
# global queda desactivado (la autorización por servidor sigue funcionando).
BOT_OWNER_ID=
